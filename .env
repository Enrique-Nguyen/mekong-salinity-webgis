# Database Configuration
# PostgreSQL connection string format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://mekong_user:mekong_password@db:5432/mekong_salinity_db

# PostgreSQL credentials
POSTGRES_USER=mekong_user
POSTGRES_PASSWORD=mekong_password
POSTGRES_DB=mekong_salinity_db

# Backend Authentication & Security
# Secret key for JWT token encoding (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# Algorithm for JWT encoding
ALGORITHM=HS256

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PgAdmin Configuration
# Email for PgAdmin login
PGADMIN_EMAIL=admin@mekong-salinity.local

# Password for PgAdmin login
PGADMIN_PASSWORD=admin_password
